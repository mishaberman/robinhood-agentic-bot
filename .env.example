OPENAI_API_KEY=

# Optional if your Robinhood MCP flow gives you a bearer token for direct API use.
# Most users will authenticate Robinhood MCP in their agent platform instead.
ROBINHOOD_OAUTH_ACCESS_TOKEN=

# Cloud database for scheduled jobs. Put real values in your host's secret manager.
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=

# Optional: generic JSON webhook for TRADE REVIEW / EXIT REVIEW alerts.
# Use a private endpoint such as Pushover/Zapier/Make/custom webhook.
ALERT_WEBHOOK_URL=

# Defaults are intentionally cautious.
OPENAI_MODEL=gpt-5.5
ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
POLL_SECONDS=30

# Keep false until you intentionally want the model to request live order placement.
# Even when true, the CLI still asks you to type a confirmation phrase before approvals.
ENABLE_REAL_ORDER_TOOLS=false
ENABLE_OPTIONS_TOOLS=false
ENABLE_LEVERAGED_ETPS=false

TARGET_ACCOUNT_HINT=Agentic
STARTING_CAPITAL_USD=2000
TARGET_VALUE_USD=3000
MAX_POSITION_NOTIONAL_USD=250
MAX_TOTAL_EXPOSURE_USD=1500
MAX_DAILY_LOSS_USD=60
MAX_TRADES_PER_DAY=8
MAX_SINGLE_TRADE_LOSS_USD=15

# Comma-separated symbols to watch. Edit freely.
WATCHLIST=MU,WDC,STX,HON,STM,ASML,MRVL,NBIS,NVDA,AMD,AVGO,DELL,HPQ,HPE,SMH
